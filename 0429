# Multi-Agent Reflection System
# ===============================

from openai import OpenAI
import re

# ====== 配置 ======
API_KEY = "your_api_key_here"   # 替换成你的key
MODEL = "gpt-4o-mini"
MAX_ITER = 3
QUALITY_THRESHOLD = 0.85

client = OpenAI(api_key=API_KEY)

# ====== LLM调用 ======
def call_llm(system_prompt, user_prompt):
    response = client.chat.completions.create(
        model=MODEL,
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": user_prompt}
        ],
        temperature=0.7,
    )
    return response.choices[0].message.content


# ====== Generator Agent ======
class GeneratorAgent:
    def run(self, query):
        system_prompt = "你是一个专业内容生成专家，请生成结构清晰、逻辑严谨的内容。"
        user_prompt = f"请根据以下需求生成内容：\n{query}"
        return call_llm(system_prompt, user_prompt)


# ====== Critic Agent ======
class CriticAgent:
    def run(self, text):
        system_prompt = "你是内容评审专家，请分析逻辑问题并给出评分（0-1）。"

        user_prompt = f"""
请分析以下内容：
{text}

输出格式：
问题：
- xxx
- xxx

评分：0.xx
"""

        response = call_llm(system_prompt, user_prompt)

        score_match = re.search(r"评分[:：]\s*(0\.\d+|1\.0)", response)
        score = float(score_match.group(1)) if score_match else 0.5

        return {
            "analysis": response,
            "score": score
        }


# ====== Verifier Agent ======
class VerifierAgent:
    def run(self, text):
        system_prompt = "你是事实验证专家，请判断内容是否存在事实错误。"

        user_prompt = f"""
请检查以下内容的事实性：

{text}

输出：
valid: true/false
reason: xxx
"""

        response = call_llm(system_prompt, user_prompt)

        valid = "true" in response.lower()

        return {
            "valid": valid,
            "detail": response
        }


# ====== Refiner Agent ======
class RefinerAgent:
    def run(self, text, critique, verification):
        system_prompt = "你是高级写作优化专家，请根据反馈优化内容。"

        user_prompt = f"""
原始内容：
{text}

评审意见：
{critique}

事实校验：
{verification}

请输出优化后的完整内容：
"""

        return call_llm(system_prompt, user_prompt)


# ====== Memory ======
class Memory:
    def __init__(self):
        self.history = []

    def add(self, step, content):
        self.history.append({
            "step": step,
            "content": content
        })


# ====== Reflection Loop ======
class ReflectionSystem:
    def __init__(self):
        self.generator = GeneratorAgent()
        self.critic = CriticAgent()
        self.verifier = VerifierAgent()
        self.refiner = RefinerAgent()
        self.memory = Memory()

    def run(self, query):
        print("\n🚀 开始生成...\n")

        draft = self.generator.run(query)
        self.memory.add("draft_0", draft)

        print("📝 初稿生成完成\n")

        for i in range(MAX_ITER):
            print(f"🔁 第 {i+1} 轮优化...")

            critique = self.critic.run(draft)
            verification = self.verifier.run(draft)

            self.memory.add(f"critique_{i}", critique)
            self.memory.add(f"verification_{i}", verification)

            print(f"评分：{critique['score']} | 是否有效：{verification['valid']}")

            if critique["score"] >= QUALITY_THRESHOLD and verification["valid"]:
                print("✅ 达到质量阈值，停止优化\n")
                break

            draft = self.refiner.run(
                draft,
                critique["analysis"],
                verification["detail"]
            )

            self.memory.add(f"refined_{i}", draft)

        return draft


# ====== 主程序 ======
if __name__ == "__main__":
    query = input("请输入你的需求：\n")

    system = ReflectionSystem()
    result = system.run(query)

    print("\n========================")
    print("🎯 最终结果：\n")
    print(result)
    print("========================")
